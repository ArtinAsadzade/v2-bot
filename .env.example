# ---------------------------------------------------------------------------
# Local development (pnpm dev outside Docker)
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=debug
API_HOST=0.0.0.0
API_PORT=4000
API_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/v2bot?schema=public
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=v2bot

# Required — replace with your real Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=v2bot
TELEGRAM_WEBHOOK_DOMAIN=

JWT_ACCESS_SECRET=replace-with-at-least-32-characters-access
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PASSWORD_PEPPER=replace-with-at-least-32-characters

XRAY_API_BASE_URL=https://xray.example.com
XRAY_API_TOKEN=replace-me
XRAY_API_TIMEOUT_MS=10000
XRAY_API_MOCK=false
XRAY_RATE_LIMIT_PER_SEC=10

CRYPTO_PAYMENTS_PROVIDER=nowpayments
CRYPTO_PAYMENTS_API_KEY=replace-me
CRYPTO_PAYMENTS_WEBHOOK_SECRET=replace-with-at-least-32-characters

REFERRAL_CASHBACK_BPS=500
REFERRAL_FIXED_BONUS_TOMAN=0
REFERRAL_REWARD_DELAY_HOURS=0
SERVICE_GRACE_PERIOD_HOURS=24
NOTIFICATION_COOLDOWN_SECONDS=3600
TICKET_RATE_LIMIT_PER_HOUR=5
INACTIVITY_REMINDER_DAYS=7

# Bot ↔ API (local dev)
API_BASE_URL=http://localhost:4000/v1
BOT_ADMIN_IDS=
SESSION_TTL_SECONDS=1209600
RATE_LIMIT_WINDOW_SECONDS=3
RATE_LIMIT_MAX_UPDATES=8

# Admin panel (browser-side; must be reachable from your machine)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Docker Compose overrides (set automatically in docker-compose.yml)
# Do NOT use localhost inside containers — use service hostnames instead:
#   postgres  → DATABASE_URL host
#   redis     → REDIS_URL host
#   api       → API_BASE_URL host (bot → api)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/v2bot?schema=public
# REDIS_URL=redis://redis:6379
# API_BASE_URL=http://api:4000/v1
