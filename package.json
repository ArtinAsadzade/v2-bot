{
  "name": "v2-bot",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "payment:audit": "ts-node scripts/payment-integrity-audit.ts",
    "payment:fix-payid-index": "ts-node scripts/fix-payment-invoice-pay-id-index.ts",
    "predev": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "deploy:pm2": "npm run prisma:generate && npm run build && pm2 restart v2-bot --update-env",
    "check:panel-views": "vitest run tests/panel-view-registry.test.ts",
    "repair:order-items": "ts-node scripts/repair-broken-order-items.ts",
    "payment:verify-flow": "node dist/scripts/verify-payment-flow.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "prisma": "^5.22.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
