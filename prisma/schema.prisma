generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  superadmin
}

enum WalletTransactionType {
  credit
  debit
  transfer_in
  transfer_out
}

enum DepositStatus {
  pending
  submitted
  approved
  rejected
  expired
}

enum TicketStatus {
  open
  closed
}

enum TicketSenderRole {
  user
  admin
}

enum ProductAccountStatus {
  available
  reserved
  sold
  disabled
  expired
}

enum ProductMode {
  manual_inventory
  xray_auto
}

enum XrayClientStatus {
  creating
  provisioning
  active
  expired
  disabled
  failed
  renewal_failed
  missing_on_panel
  deleted
}

enum OrderStatus {
  completed
  cancelled
  failed
  failed_delivery
}

enum ReferralRewardStatus {
  pending
  claimable
  claimed
}

enum FreeConfigRewardStatus {
  available
  claimed
}

enum FreeAccountStatus {
  available
  assigned
  expired
}

enum CouponType {
  percentage
  fixed
}

enum CouponStatus {
  active
  inactive
  deleted
}

enum ForcedJoinChannelStatus {
  active
  inactive
}

enum CryptoWalletStatus {
  active
  inactive
}

enum StoreStatus {
  active
  inactive
}

enum PaymentInvoiceType {
  WALLET_TOPUP
  PRODUCT_PURCHASE
  XRAY_RENEWAL
}

enum PaymentInvoiceStatus {
  PENDING
  PAID
  COMPLETED
  CANCELED
  EXPIRED
  FAILED
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  telegramId   String   @unique
  username     String?
  firstName    String?
  lastName     String?
  balance      Int      @default(0)
  role         Role     @default(user)
  isBanned     Boolean  @default(false)
  referralCode String?  @unique
  referredById String?  @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  walletTransactions     WalletTransaction[]
  deposits               Deposit[]
  tickets                Ticket[]
  couponUsages           CouponUsage[]
  orders                 Order[]
  referralsMade          Referral[]              @relation("Referrer")
  referredReferral       Referral?               @relation("Referred")
  referralRewards        ReferralReward[]
  freeConfigRewards      FreeConfigReward[]
  freeAccountAssignments FreeAccountAssignment[]
  paymentInvoices        PaymentInvoice[]
  paymentAuditLogs       PaymentAuditLog[]
  xrayClients            XrayClient[]
  xrayRenewals           XrayRenewal[]

  @@index([role])
  @@index([referredById])
  @@index([createdAt])
}

model Referral {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  referrerId String   @db.ObjectId
  referredId String   @unique @db.ObjectId
  createdAt  DateTime @default(now())

  referrer User             @relation("Referrer", fields: [referrerId], references: [id])
  referred User             @relation("Referred", fields: [referredId], references: [id])
  rewards  ReferralReward[]

  @@index([referrerId, createdAt])
}

model ReferralReward {
  id         String               @id @default(auto()) @map("_id") @db.ObjectId
  referralId String?              @db.ObjectId
  tierId     String?              @db.ObjectId
  userId     String               @db.ObjectId
  threshold  Int                  @default(1)
  amount     Int
  status     ReferralRewardStatus @default(claimable)
  createdAt  DateTime             @default(now())
  claimedAt  DateTime?

  referral Referral?           @relation(fields: [referralId], references: [id])
  tier     ReferralRewardTier? @relation(fields: [tierId], references: [id])
  user     User                @relation(fields: [userId], references: [id])

  @@unique([userId, threshold])
  @@index([userId, status])
  @@index([referralId])
  @@index([tierId])
}

model ReferralRewardTier {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  threshold Int      @unique
  amount    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rewards ReferralReward[]

  @@index([isActive, threshold])
}

model FreeConfigReward {
  id        String                 @id @default(auto()) @map("_id") @db.ObjectId
  userId    String                 @db.ObjectId
  config    String
  reason    String
  status    FreeConfigRewardStatus @default(available)
  createdAt DateTime               @default(now())
  claimedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([createdAt])
}

model WalletTransaction {
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  userId      String                @db.ObjectId
  amount      Int
  type        WalletTransactionType
  description String
  createdAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Deposit {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  userId         String        @db.ObjectId
  amount         Int
  cryptoType     String
  wallet         String
  networkName    String?
  cryptoAmount   Float?
  exchangeRate   Int?
  cryptoWalletId String?       @db.ObjectId
  status         DepositStatus @default(pending)
  receipt        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  expiresAt      DateTime
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewAction   String?

  user         User          @relation(fields: [userId], references: [id])
  cryptoWallet CryptoWallet? @relation(fields: [cryptoWalletId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model CryptoWallet {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  coinName      String
  coinSymbol    String?
  walletAddress String
  networkName   String
  displayName   String?
  displayOrder  Int                @default(0)
  status        CryptoWalletStatus @default(active)
  rateToman     Int                @default(0)
  lastRateAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  deposits Deposit[]

  @@unique([coinName, networkName])
  @@index([status, displayOrder])
}

model FinancialSetting {
  id                 String      @id @default("singleton") @map("_id")
  minimumTopupAmount Int         @default(100000)
  storeStatus        StoreStatus @default(active)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model PaymentGatewayConfig {
  id                    String    @id @default("singleton") @map("_id")
  enabled               Boolean   @default(false)
  apiBaseUrl            String
  apiKey                String
  callbackUrl           String
  gatewayName           String    @default("پرداخت آنی")
  displayOrder          Int       @default(1)
  lastSuccessfulRequest DateTime?
  lastFailedRequest     DateTime?
  lastConnectionStatus  String?
  lastConnectionError   String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([enabled, displayOrder])
}

model PaymentInvoice {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  userId             String               @db.ObjectId
  amount             Int
  originalAmount     Int                  @default(0)
  discountAmount     Int                  @default(0)
  couponId           String?              @db.ObjectId
  couponCode         String?
  gatewayAmount      Int?
  payId              String?
  paymentLink        String?
  gatewayResponse    String?
  callbackCount      Int                  @default(0)
  lastCallbackAt     DateTime?
  deliveryStatus     String?
  notificationStatus String?
  callbackToken      String               @unique
  type               PaymentInvoiceType
  status             PaymentInvoiceStatus @default(PENDING)
  productId          String?              @db.ObjectId
  depositId          String?              @db.ObjectId
  orderId            String?              @db.ObjectId
  renewalId          String?              @db.ObjectId
  renewalXrayClientId String?             @db.ObjectId
  createdAt          DateTime             @default(now())
  paidAt             DateTime?
  verifiedAt         DateTime?
  completedAt        DateTime?
  updatedAt          DateTime             @updatedAt

  user    User              @relation(fields: [userId], references: [id])
  product Product?          @relation(fields: [productId], references: [id])
  coupon  Coupon?           @relation(fields: [couponId], references: [id])
  order   Order?            @relation(fields: [orderId], references: [id])
  renewal XrayRenewal?      @relation(fields: [renewalId], references: [id])
  audits  PaymentAuditLog[]

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@index([type, status, createdAt])
  @@index([productId, status])
  @@index([couponId])
  @@index([orderId])
  @@index([depositId])
  @@index([payId])
}

model PaymentAuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  invoiceId String   @db.ObjectId
  action    String
  metadata  String?
  createdAt DateTime @default(now())

  user    User?          @relation(fields: [userId], references: [id])
  invoice PaymentInvoice @relation(fields: [invoiceId], references: [id])

  @@index([userId, createdAt])
  @@index([invoiceId, createdAt])
  @@index([action, createdAt])
}

model Ticket {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  userId    String       @db.ObjectId
  status    TicketStatus @default(open)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  messages TicketMessage[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model TicketMessage {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  ticketId   String           @db.ObjectId
  senderId   String
  senderRole TicketSenderRole
  message    String
  createdAt  DateTime         @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
}

model Coupon {
  id                    String       @id @default(auto()) @map("_id") @db.ObjectId
  code                  String       @unique
  type                  CouponType   @default(percentage)
  value                 Int
  discountPercent       Int?
  maxUses               Int
  usedCount             Int          @default(0)
  perUserLimit          Int          @default(1)
  minimumPurchaseAmount Int          @default(0)
  status                CouponStatus @default(active)
  expiresAt             DateTime
  deletedAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  usages          CouponUsage[]
  orders          Order[]
  paymentInvoices PaymentInvoice[]

  @@index([status, expiresAt])
  @@index([deletedAt])
}

model CouponUsage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  couponId  String   @db.ObjectId
  userId    String   @db.ObjectId
  orderId   String?  @db.ObjectId
  usageSlot Int      @default(0)
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId, usageSlot])
  @@index([couponId, userId])
  @@index([userId, createdAt])
}

model Category {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String    @unique
  description  String?
  icon         String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]

  @@index([isActive, displayOrder])
  @@index([deletedAt])
}

model Product {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  categoryId        String      @db.ObjectId
  title             String
  price             Int
  duration          Int
  mode              ProductMode @default(manual_inventory)
  trafficBytes      BigInt?
  durationDays      Int?
  stockLimit        Int?
  soldCount         Int         @default(0)
  inboundIds        Int[]
  inboundSnapshot   String?
  xrayLimitIp      Int         @default(0)
  xrayGroupName    String?
  xrayPanelConfigId String?     @db.ObjectId
  isActive          Boolean     @default(true)
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id])
  accounts        ProductAccount[]
  orders          Order[]
  orderItems      OrderItem[]
  paymentInvoices PaymentInvoice[]
  xrayClients     XrayClient[]
  xrayRenewals    XrayRenewal[]

  @@index([categoryId])
  @@index([isActive, deletedAt])
}

model ProductAccount {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  productId        String               @db.ObjectId
  username         String
  password         String?
  subscriptionLink String
  configLink       String
  config           String
  durationDays     Int?
  status           ProductAccountStatus @default(available)
  reservedBy       String?              @db.ObjectId
  reservedAt       DateTime?
  soldTo           String?              @db.ObjectId
  soldAt           DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  product Product                 @relation(fields: [productId], references: [id])
  items   OrderItem[]
  history ProductAccountHistory[]

  @@index([productId, status])
  @@index([reservedBy])
  @@index([soldTo])
}

model ProductAccountHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId String   @db.ObjectId
  actorId   String
  action    String
  fromValue String?
  toValue   String?
  metadata  String?
  createdAt DateTime @default(now())

  account ProductAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
}

model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  userId          String      @db.ObjectId
  productId       String      @db.ObjectId
  couponId        String?     @db.ObjectId
  originalAmount  Int
  totalAmount     Int
  finalPaidAmount Int
  discountAmount  Int         @default(0)
  status          OrderStatus @default(completed)
  createdAt       DateTime    @default(now())

  user            User             @relation(fields: [userId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  coupon          Coupon?          @relation(fields: [couponId], references: [id])
  items           OrderItem[]
  paymentInvoices PaymentInvoice[]
  xrayClients     XrayClient[]

  @@index([userId, createdAt])
  @@index([productId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id                        String    @id @default(auto()) @map("_id") @db.ObjectId
  orderId                   String    @db.ObjectId
  productId                 String    @db.ObjectId
  productAccountId          String?   @db.ObjectId
  xrayClientId              String?   @db.ObjectId
  deliveredUsername         String
  deliveredPassword         String?
  deliveredSubscriptionLink String?
  deliveredConfigLink       String?
  deliveredConfig           String
  purchaseDate              DateTime  @default(now())
  expiresAt                 DateTime?
  isActive                  Boolean   @default(true)

  order          Order           @relation(fields: [orderId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  productAccount ProductAccount? @relation(fields: [productAccountId], references: [id])
  xrayClient     XrayClient?     @relation(fields: [xrayClientId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([productAccountId])
  @@index([xrayClientId])
  @@index([expiresAt, isActive])
}

model XrayPanelConfig {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  name                String    @default("default")
  apiBaseUrl          String
  apiToken            String
  subscriptionBaseUrl String?
  enabled             Boolean   @default(false)
  lastSuccessAt       DateTime?
  lastError           String?
  lastInboundCount    Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  clients XrayClient[]
}

model XrayClient {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  panelConfigId String?          @db.ObjectId
  userId        String           @db.ObjectId
  telegramId    String
  productId     String?          @db.ObjectId
  orderId       String?          @db.ObjectId
  isFreeTest    Boolean          @default(false)
  clientEmail   String           @unique
  clientSubId   String?
  panelClientId String?
  inboundIds    Int[]
  limitIp       Int      @default(0)
  groupName     String?
  expiresAt     DateTime
  trafficBytes  BigInt
  usedBytes     BigInt           @default(0)
  status        XrayClientStatus @default(provisioning)
  lastError     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  panelConfig XrayPanelConfig? @relation(fields: [panelConfigId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  product     Product?         @relation(fields: [productId], references: [id])
  order       Order?           @relation(fields: [orderId], references: [id])
  orderItems  OrderItem[]
  renewals    XrayRenewal[]

  @@index([userId, status])
  @@index([productId, createdAt])
  @@index([orderId])
}

model XrayRenewal {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  userId             String           @db.ObjectId
  xrayClientId       String           @db.ObjectId
  renewalProductId   String           @db.ObjectId
  invoiceId          String?          @db.ObjectId
  oldTotalBytes      BigInt
  newTotalBytes      BigInt
  oldExpiry          DateTime
  newExpiry          DateTime
  oldUsedBytes       BigInt           @default(0)
  oldRemainingBytes  BigInt           @default(0)
  addTrafficBytes    BigInt
  addDays            Int
  status             XrayClientStatus @default(provisioning)
  lastError          String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id])
  xrayClient     XrayClient       @relation(fields: [xrayClientId], references: [id])
  renewalProduct Product          @relation(fields: [renewalProductId], references: [id])
  invoices       PaymentInvoice[]

  @@index([userId, createdAt])
  @@index([xrayClientId, createdAt])
  @@index([invoiceId])
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId   String
  action    String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model DailyStats {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime @unique
  users     Int
  deposits  Int
  purchases Int
  revenue   Int
}

model SecurityFlag {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  type      String
  reason    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model FreeAccount {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  username         String
  subscriptionLink String
  configLink       String
  durationDays     Int
  status           FreeAccountStatus @default(available)
  assignedTo       String?           @db.ObjectId
  assignedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  assignment FreeAccountAssignment?

  @@index([status, createdAt])
  @@index([assignedTo, assignedAt])
}

model FreeAccountAssignment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  accountId  String   @unique @db.ObjectId
  reason     String
  isActive   Boolean  @default(true)
  assignedAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id])
  account FreeAccount @relation(fields: [accountId], references: [id])

  @@index([userId, isActive, assignedAt])
  @@index([expiresAt, isActive])
  @@index([createdAt])
}

model FreeAccountUserLock {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @unique @db.ObjectId
  lastClaimAt      DateTime
  lastAssignmentId String?  @db.ObjectId
  updatedAt        DateTime @updatedAt

  @@index([lastClaimAt])
}

model UserBlockHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  actorId   String
  blocked   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([actorId, createdAt])
}

model ForcedJoinChannel {
  id                    String                  @id @default(auto()) @map("_id") @db.ObjectId
  chatId                String                  @unique
  title                 String
  inviteLink            String?
  status                ForcedJoinChannelStatus @default(active)
  lastBotAdminStatus    String?
  lastBotAdminCheckedAt DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([status])
}

model ProductGuideSection {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  shortDescription String
  body             String
  icon             String   @default("📘")
  isActive         Boolean  @default(true)
  displayOrder     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive, displayOrder])
  @@index([createdAt])
}

model PublicPlansSetting {
  id        String   @id @default("singleton") @map("_id")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccountExpirationNotification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderItemId String   @db.ObjectId
  daysBefore  Int
  sentAt      DateTime @default(now())

  @@unique([orderItemId, daysBefore])
  @@index([sentAt])
}


model FreeTestConfig {
  id              String   @id @default("singleton") @map("_id")
  enabled         Boolean  @default(false)
  trafficBytes    BigInt   @default(0)
  durationDays    Int      @default(1)
  stockLimit      Int      @default(0)
  usedCount       Int      @default(0)
  inboundIds      Int[]
  inboundSnapshot String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
