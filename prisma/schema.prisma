generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  superadmin
}

enum WalletTransactionType {
  credit
  debit
  transfer_in
  transfer_out
}

enum DepositStatus {
  pending
  submitted
  approved
  rejected
  expired
}

enum TicketStatus {
  open
  closed
}

enum TicketSenderRole {
  user
  admin
}

enum ProductAccountStatus {
  available
  reserved
  sold
}

enum OrderStatus {
  completed
  cancelled
  failed
}

enum ReferralRewardStatus {
  pending
  claimed
}

enum FreeConfigRewardStatus {
  available
  claimed
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  telegramId String   @unique
  username   String?
  firstName  String?
  lastName   String?
  balance    Int      @default(0)
  role       Role     @default(user)
  isBanned   Boolean  @default(false)
  referralCode String?  @unique
  referredById String?  @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  walletTransactions WalletTransaction[]
  deposits           Deposit[]
  tickets            Ticket[]
  couponUsages       CouponUsage[]
  orders             Order[]
  referralsMade      Referral[]          @relation("Referrer")
  referredReferral   Referral?           @relation("Referred")
  referralRewards    ReferralReward[]
  freeConfigRewards  FreeConfigReward[]

  @@index([role])
  @@index([referredById])
  @@index([createdAt])
}

model Referral {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  referrerId String   @db.ObjectId
  referredId String   @unique @db.ObjectId
  createdAt  DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referred User @relation("Referred", fields: [referredId], references: [id])
  rewards  ReferralReward[]

  @@index([referrerId, createdAt])
}

model ReferralReward {
  id         String               @id @default(auto()) @map("_id") @db.ObjectId
  referralId String               @db.ObjectId
  userId     String               @db.ObjectId
  amount     Int
  status     ReferralRewardStatus @default(pending)
  createdAt  DateTime             @default(now())
  claimedAt  DateTime?

  referral Referral @relation(fields: [referralId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([referralId])
}

model FreeConfigReward {
  id        String                 @id @default(auto()) @map("_id") @db.ObjectId
  userId    String                 @db.ObjectId
  config    String
  reason    String
  status    FreeConfigRewardStatus @default(available)
  createdAt DateTime               @default(now())
  claimedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([createdAt])
}

model WalletTransaction {
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  userId      String                @db.ObjectId
  amount      Int
  type        WalletTransactionType
  description String
  createdAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Deposit {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  userId     String        @db.ObjectId
  amount     Int
  cryptoType String
  wallet     String
  status     DepositStatus @default(pending)
  receipt    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model Ticket {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  userId    String       @db.ObjectId
  status    TicketStatus @default(open)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  messages TicketMessage[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model TicketMessage {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  ticketId   String           @db.ObjectId
  senderId   String
  senderRole TicketSenderRole
  message    String
  createdAt  DateTime         @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
}

model Coupon {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  code            String   @unique
  discountPercent Int
  maxUses         Int
  usedCount       Int      @default(0)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usages CouponUsage[]
  orders Order[]

  @@index([expiresAt])
}

model CouponUsage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  couponId  String   @db.ObjectId
  userId    String   @db.ObjectId
  orderId   String?  @db.ObjectId
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
  @@index([userId, createdAt])
}

model Category {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  categoryId String   @db.ObjectId
  title      String
  price      Int
  duration   Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category         @relation(fields: [categoryId], references: [id])
  accounts   ProductAccount[]
  orders     Order[]
  orderItems OrderItem[]
  freeAccountPool FreeAccountPool[]

  @@index([categoryId])
  @@index([isActive])
}

model ProductAccount {
  id         String               @id @default(auto()) @map("_id") @db.ObjectId
  productId  String               @db.ObjectId
  username   String
  password   String
  config     String
  status     ProductAccountStatus @default(available)
  reservedBy String?              @db.ObjectId
  reservedAt DateTime?
  soldTo     String?              @db.ObjectId
  soldAt     DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  product Product @relation(fields: [productId], references: [id])
  items   OrderItem[]

  @@index([productId, status])
  @@index([reservedBy])
  @@index([soldTo])
}

model Order {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  userId         String      @db.ObjectId
  productId      String      @db.ObjectId
  couponId       String?     @db.ObjectId
  totalAmount    Int
  discountAmount Int         @default(0)
  status         OrderStatus @default(completed)
  createdAt      DateTime    @default(now())

  user    User        @relation(fields: [userId], references: [id])
  product Product     @relation(fields: [productId], references: [id])
  coupon  Coupon?     @relation(fields: [couponId], references: [id])
  items   OrderItem[]

  @@index([userId, createdAt])
  @@index([productId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id                 String @id @default(auto()) @map("_id") @db.ObjectId
  orderId            String @db.ObjectId
  productId          String @db.ObjectId
  productAccountId   String @db.ObjectId
  deliveredUsername  String
  deliveredPassword  String
  deliveredConfig    String

  order          Order          @relation(fields: [orderId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])
  productAccount ProductAccount @relation(fields: [productAccountId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([productAccountId])
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId   String
  action    String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model DailyStats {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime @unique
  users     Int
  deposits  Int
  purchases Int
  revenue   Int
}

model SecurityFlag {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  type      String
  reason    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model FreeAccountPool {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  username  String
  password  String
  config    String
  isAssigned Boolean @default(false)
  assignedTo String? @db.ObjectId
  assignedAt DateTime?
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, isAssigned])
  @@index([assignedTo])
}
