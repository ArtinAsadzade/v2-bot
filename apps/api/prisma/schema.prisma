model XrayNode {
  id               String            @id @default(uuid()) @db.Uuid
  name             String            @db.VarChar(120)
  region           String?           @db.VarChar(80)
  baseUrl          String            @map("base_url")
  isActive         Boolean           @default(true) @map("is_active")
  priority         Int               @default(100)
  maxClients       Int?              @map("max_clients")
  metadata         Json?
  products         Product[]
  xrayClients      XrayClient[]
  serviceInstances ServiceInstance[]
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([isActive, priority])
  @@index([region])
  @@map("xray_nodes")
}

model XrayClient {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId        String           @map("product_id") @db.Uuid
  product          Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchaseId       String           @unique @map("purchase_id") @db.Uuid
  purchase         Purchase         @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  nodeId           String?          @map("node_id") @db.Uuid
  node             XrayNode?        @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  serviceInstance  ServiceInstance?
  inboundId        Int              @map("inbound_id")
  panelClientId    String?          @map("panel_client_id") @db.VarChar(128)
  clientUuid       String           @unique @map("client_uuid") @db.Uuid
  email            String           @unique @db.VarChar(255)
  subscriptionId   String           @unique @map("subscription_id") @db.VarChar(128)
  subscriptionUrl  String           @map("subscription_url")
  configLinks      String[]         @map("config_links")
  subscriptionLinks SubscriptionLink[]
  configLinkRows   ConfigLink[]
  trafficLimitGb   Int              @map("traffic_limit_gb")
  usedBytes        BigInt           @default(0) @map("used_bytes")
  status           XrayClientStatus @default(ACTIVE)
  expiresAt        DateTime         @map("expires_at") @db.Timestamptz(3)
  lastSyncedAt     DateTime?        @map("last_synced_at") @db.Timestamptz(3)
  metadata         Json?
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(3)

  @@index([userId, status])
  @@index([inboundId, status])
  @@index([expiresAt])
  @@index([nodeId, status])
  @@map("xray_clients")
}

model ServiceInstance {
  id               String                @id @default(uuid()) @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId        String                @map("product_id") @db.Uuid
  product          Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchaseId       String                @unique @map("purchase_id") @db.Uuid
  purchase         Purchase              @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  xrayClientId     String?               @unique @map("xray_client_id") @db.Uuid
  xrayClient       XrayClient?           @relation(fields: [xrayClientId], references: [id], onDelete: SetNull)
  nodeId           String?               @map("node_id") @db.Uuid
  node             XrayNode?             @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  inboundId        Int                   @map("inbound_id")
  status           ServiceInstanceStatus @default(PROVISIONING)
  trafficLimitGb   Int                   @map("traffic_limit_gb")
  usedBytes        BigInt                @default(0) @map("used_bytes")
  expiresAt        DateTime              @map("expires_at") @db.Timestamptz(3)
  idempotencyKey   String                @unique @map("idempotency_key") @db.VarChar(160)
  lastSyncedAt     DateTime?             @map("last_synced_at") @db.Timestamptz(3)
  metadata         Json?
  usageSnapshots   ServiceUsageSnapshot[]
  provisioningJobs ProvisioningJob[]
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt        DateTime?             @map("deleted_at") @db.Timestamptz(3)

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([nodeId, status])
  @@map("service_instances")
}

model ServiceUsageSnapshot {
  id                String          @id @default(uuid()) @db.Uuid
  serviceInstanceId String          @map("service_instance_id") @db.Uuid
  serviceInstance   ServiceInstance @relation(fields: [serviceInstanceId], references: [id], onDelete: Cascade)
  usedBytes         BigInt          @map("used_bytes")
  uploadBytes       BigInt          @default(0) @map("upload_bytes")
  downloadBytes     BigInt          @default(0) @map("download_bytes")
  remainingBytes    BigInt?         @map("remaining_bytes")
  syncedAt          DateTime        @default(now()) @map("synced_at") @db.Timestamptz(3)
  metadata          Json?

  @@index([serviceInstanceId, syncedAt])
  @@map("service_usage_snapshots")
}

model ProvisioningJob {
  id                String                @id @default(uuid()) @db.Uuid
  serviceInstanceId String                @map("service_instance_id") @db.Uuid
  serviceInstance   ServiceInstance       @relation(fields: [serviceInstanceId], references: [id], onDelete: Cascade)
  status            ProvisioningJobStatus @default(PENDING)
  attempt           Int                   @default(0)
  maxAttempts       Int                   @default(5) @map("max_attempts")
  idempotencyKey    String                @unique @map("idempotency_key") @db.VarChar(160)
  lastError         String?               @map("last_error")
  nextRetryAt       DateTime?             @map("next_retry_at") @db.Timestamptz(3)
  completedAt       DateTime?             @map("completed_at") @db.Timestamptz(3)
  metadata          Json?
  logs              ProvisioningLog[]
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, nextRetryAt])
  @@index([serviceInstanceId, status])
  @@map("provisioning_jobs")
}

model ProvisioningLog {
  id                String              @id @default(uuid()) @db.Uuid
  provisioningJobId String              @map("provisioning_job_id") @db.Uuid
  provisioningJob   ProvisioningJob     @relation(fields: [provisioningJobId], references: [id], onDelete: Cascade)
  level             ProvisioningLogLevel @default(INFO)
  message           String              @db.VarChar(500)
  metadata          Json?
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([provisioningJobId, createdAt])
  @@map("provisioning_logs")
}

model SubscriptionLink {
  id           String     @id @default(uuid()) @db.Uuid
  xrayClientId String     @map("xray_client_id") @db.Uuid
  xrayClient   XrayClient @relation(fields: [xrayClientId], references: [id], onDelete: Cascade)
