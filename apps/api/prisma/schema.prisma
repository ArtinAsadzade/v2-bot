generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ProductStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ServiceStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DELETED
}

enum TicketStatus {
  OPEN
  WAITING_ADMIN
  WAITING_USER
  CLOSED
}

enum AdminRole {
  OWNER
  SUPPORT
  FINANCE
  OPERATOR
}

model User {
  id                String          @id @default(uuid())
  telegramId        String          @unique
  username          String?
  firstName         String?
  lastName          String?
  status            UserStatus      @default(ACTIVE)
  referralCode      String          @unique
  referredById      String?
  referredBy        User?           @relation("UserReferrals", fields: [referredById], references: [id])
  referrals         User[]          @relation("UserReferrals")
  wallet            Wallet?
  transactions      Transaction[]
  purchases         Purchase[]
  services          XrayClient[]
  tickets           Ticket[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([telegramId])
  @@index([referralCode])
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])
  balanceToman BigInt        @default(0)
  ledger       WalletLedger[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model WalletLedger {
  id             String              @id @default(uuid())
  walletId       String
  wallet         Wallet              @relation(fields: [walletId], references: [id])
  direction      LedgerDirection
  amountToman    BigInt
  balanceAfter   BigInt
  reason         String
  idempotencyKey String              @unique
  createdAt      DateTime            @default(now())
}

model Transaction {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  amountToman    BigInt
  provider       String
  providerRef    String?
  status         TransactionStatus @default(PENDING)
  idempotencyKey String            @unique
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Product {
  id            String        @id @default(uuid())
  name          String
  description   String?
  inboundId     Int
  category      String
  pricePerGb    BigInt
  protocol      String
  minTrafficGb  Int           @default(1)
  maxTrafficGb  Int           @default(500)
  durationDays  Int           @default(30)
  status        ProductStatus @default(ACTIVE)
  purchases     Purchase[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, category])
}

model Purchase {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  trafficGb      Int
  amountToman    BigInt
  idempotencyKey String      @unique
  xrayClient     XrayClient?
  createdAt      DateTime    @default(now())
}

model XrayClient {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  purchaseId      String        @unique
  purchase        Purchase      @relation(fields: [purchaseId], references: [id])
  productId       String
  inboundId       Int
  clientId        String
  email           String        @unique
  subId           String        @unique
  configLinks     String[]
  subscriptionUrl String
  trafficGb       Int
  usedBytes       BigInt        @default(0)
  expiresAt       DateTime
  status          ServiceStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, status])
  @@index([email])
}

model ReferralReward {
  id          String   @id @default(uuid())
  referrerId  String
  refereeId   String
  amountToman BigInt
  purchaseId  String?
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())
}

model Ticket {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  subject   String
  status    TicketStatus    @default(OPEN)
  messages  TicketMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  authorId  String
  body      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         AdminRole
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
}
