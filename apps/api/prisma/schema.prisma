generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

enum WalletTransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  ADMIN_ADJUSTMENT
  REFERRAL_REWARD
  BONUS
  PENALTY
}

enum WalletTransactionDirection {
  CREDIT
  DEBIT
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  EXPIRED
}

enum CurrencyCode {
  TOMAN
  USDT
  TON
  BTC
  ETH
}

enum PaymentInvoiceStatus {
  PENDING
  CONFIRMING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum PaymentNetwork {
  TRON
  TON
  BITCOIN
  ETHEREUM
}

enum PaymentWebhookStatus {
  RECEIVED
  VERIFIED
  REJECTED
  PROCESSED
  FAILED
}

enum ReferralRewardStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum CouponStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

enum PricingRuleStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PurchaseDraftStatus {
  DRAFT
  FUNDS_RESERVED
  CANCELLED
  EXPIRED
  CONVERTED
}

enum FinancialAuditAction {
  WALLET_CREATED
  WALLET_CREDITED
  WALLET_DEBITED
  WALLET_FROZEN
  WALLET_UNLOCKED
  INVOICE_CREATED
  PAYMENT_VERIFIED
  PAYMENT_EXPIRED
  ADMIN_ADJUSTMENT
  REFERRAL_REWARD_APPLIED
  PURCHASE_DRAFT_CREATED
  RECONCILIATION_CHECKED
  PURCHASE_COMPLETED
  PROVISION_ROLLBACK
}

enum ProductStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PurchaseStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ReferralStatus {
  PENDING
  REWARDED
  CANCELED
}

enum AdminRole {
  OWNER
  ADMIN
  SUPPORT
  FINANCE
  OPERATOR
}

enum NotificationChannel {
  TELEGRAM
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum SupportTicketStatus {
  OPEN
  WAITING_ADMIN
  WAITING_USER
  CLOSED
}

enum TicketCategory {
  PAYMENT
  TECHNICAL
  ACCOUNT
  GENERAL
}

enum NotificationType {
  SERVICE_EXPIRING
  SERVICE_EXPIRED
  TRAFFIC_WARNING
  DEPOSIT_SUCCESS
  PURCHASE_CONFIRMATION
  REFERRAL_REWARD
  SYSTEM_ANNOUNCEMENT
  ADMIN_BROADCAST
  INACTIVITY_REMINDER
}

enum ReferralAttributionSource {
  TELEGRAM_START
  LINK
  MANUAL
  OTHER
}

enum SystemEventType {
  USER_CREATED
  REFERRAL_ACTIVATED
  PURCHASE_COMPLETED
  SERVICE_EXPIRING
  SERVICE_EXPIRED
  PAYMENT_SUCCESS
  TICKET_CREATED
  NOTIFICATION_SENT
}

enum SystemEventStatus {
  PENDING
  PROCESSED
  FAILED
}

enum UserActivityType {
  DAILY_LOGIN
  COMMAND
  PURCHASE
  TICKET_CREATED
  REFERRAL_SHARED
  NOTIFICATION_OPENED
}

enum AnalyticsMetricKey {
  ACTIVE_USERS
  PURCHASES
  REFERRAL_CONVERSIONS
  RENEWALS
  NOTIFICATIONS_SENT
  TICKETS_CREATED
}

enum XrayClientStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DELETED
}

enum ProductCategory {
  STANDARD
  PREMIUM
  TRIAL
  ENTERPRISE
}

enum PricingStrategy {
  FIXED
  PER_GB
  HYBRID
}

enum ServiceInstanceStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  EXPIRED
  DISABLED
  DELETED
  FAILED
}

enum ProvisioningJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ProvisioningLogLevel {
  INFO
  WARN
  ERROR
}

enum LinkProtocol {
  VLESS
  VMESS
  TROJAN
  SHADOWSOCKS
  HYSTERIA
  HYSTERIA2
  OTHER
}

enum AuditActorType {
  USER
  ADMIN
  SYSTEM
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  telegramId      String           @unique @map("telegram_id") @db.VarChar(32)
  username        String?          @db.VarChar(64)
  firstName       String?          @map("first_name") @db.VarChar(128)
  lastName        String?          @map("last_name") @db.VarChar(128)
  languageCode    String?          @map("language_code") @db.VarChar(16)
  status          UserStatus       @default(ACTIVE)
  referralCode    String           @unique @map("referral_code") @db.VarChar(32)
  referredById    String?          @map("referred_by_id") @db.Uuid
  referredBy      User?            @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals       User[]           @relation("UserReferrals")
  wallet          Wallet?
  purchases       Purchase[]
  paymentInvoices PaymentInvoice[]
  purchaseDrafts  PurchaseDraft[]
  referralRewards Referral[]       @relation("ReferralReferrer")
  referredRewards Referral[]       @relation("ReferralReferee")
  referralPayouts ReferralReward[] @relation("ReferralRewardReferrer")
  referredPayouts ReferralReward[] @relation("ReferralRewardReferee")
  notifications   Notification[]
  notificationLogs NotificationLog[]
  supportTickets  SupportTicket[]
  activityLogs    UserActivityLog[]
  engagementScore EngagementScore?
  referralAttributions ReferralAttributionLog[] @relation("ReferralAttributionInviter")
  invitedAttributions ReferralAttributionLog[] @relation("ReferralAttributionInvitee")
  xrayClients      XrayClient[]
  serviceInstances ServiceInstance[]
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(3)

  @@index([status, createdAt])
  @@index([referredById])
  @@map("users")
}

model Wallet {
  id                    String              @id @default(uuid()) @db.Uuid
  userId                String              @unique @map("user_id") @db.Uuid
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceToman          BigInt              @default(0) @map("balance_toman")
  frozenBalanceToman    BigInt              @default(0) @map("frozen_balance_toman")
  lifetimeDepositsToman BigInt              @default(0) @map("lifetime_deposits_toman")
  lifetimeSpendingToman BigInt              @default(0) @map("lifetime_spending_toman")
  currency              CurrencyCode        @default(TOMAN)
  version               Int                 @default(0)
  transactions          WalletTransaction[]
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId, currency])
  @@map("wallets")
}

model WalletTransaction {
  id               String                     @id @default(uuid()) @db.Uuid
  walletId         String                     @map("wallet_id") @db.Uuid
  wallet           Wallet                     @relation(fields: [walletId], references: [id], onDelete: Restrict)
  userId           String                     @map("user_id") @db.Uuid
  type             WalletTransactionType
  direction        WalletTransactionDirection
  status           WalletTransactionStatus    @default(PENDING)
  amountToman      BigInt                     @map("amount_toman")
  balanceBefore    BigInt                     @map("balance_before")
  balanceAfter     BigInt                     @map("balance_after")
  frozenBefore     BigInt                     @default(0) @map("frozen_before")
  frozenAfter      BigInt                     @default(0) @map("frozen_after")
  currency         CurrencyCode               @default(TOMAN)
  reason           String                     @db.VarChar(240)
  referenceId      String?                    @map("reference_id") @db.VarChar(160)
  provider         String?                    @db.VarChar(64)
  providerRef      String?                    @map("provider_ref") @db.VarChar(160)
  idempotencyKey   String                     @unique @map("idempotency_key") @db.VarChar(160)
  metadata         Json?
  paymentInvoiceId String?                    @map("payment_invoice_id") @db.Uuid
  paymentInvoice   PaymentInvoice?            @relation(fields: [paymentInvoiceId], references: [id], onDelete: SetNull)
  createdAt        DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([walletId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([type, status])
  @@index([referenceId])
  @@map("wallet_transactions")
}

model Product {
  id              String          @id @default(uuid()) @db.Uuid
  name            String          @db.VarChar(160)
  slug            String          @unique @db.VarChar(180)
  description     String?
  inboundId       Int             @map("inbound_id")
  protocol        String          @db.VarChar(32)
  category        ProductCategory @default(STANDARD)
  nodeId          String?         @map("node_id") @db.Uuid
  node            XrayNode?       @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  priceToman      BigInt          @map("price_toman")
  trafficGb       Int             @map("traffic_gb")
  durationDays    Int             @map("duration_days")
  pricingStrategy PricingStrategy @default(FIXED) @map("pricing_strategy")
  status          ProductStatus   @default(ACTIVE)
  metadata        Json?
  purchases       Purchase[]
  purchaseDrafts  PurchaseDraft[]
  xrayClients     XrayClient[]
  serviceInstances ServiceInstance[]
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz(3)

  @@index([status, protocol])
  @@index([inboundId])
  @@index([nodeId, status])
  @@map("products")
}

model Purchase {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  productId      String         @map("product_id") @db.Uuid
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  status         PurchaseStatus @default(PENDING)
  amountToman    BigInt         @map("amount_toman")
  trafficGb      Int            @map("traffic_gb")
  idempotencyKey String         @unique @map("idempotency_key") @db.VarChar(128)
  metadata       Json?
  xrayClient       XrayClient?
  serviceInstance  ServiceInstance?
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(3)

  @@index([userId, createdAt])
  @@index([productId, status])
  @@map("purchases")
}

model Referral {
  id          String         @id @default(uuid()) @db.Uuid
  referrerId  String         @map("referrer_id") @db.Uuid
  referrer    User           @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Restrict)
  refereeId   String         @map("referee_id") @db.Uuid
  referee     User           @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: Restrict)
  purchaseId  String?        @map("purchase_id") @db.Uuid
  rewardToman BigInt         @default(0) @map("reward_toman")
  status      ReferralStatus @default(PENDING)
  source      ReferralAttributionSource @default(TELEGRAM_START)
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([referrerId, refereeId])
  @@index([referrerId, status])
  @@index([refereeId])
  @@map("referrals")
}

model ReferralAttributionLog {
  id         String                  @id @default(uuid()) @db.Uuid
  inviterId  String                  @map("inviter_id") @db.Uuid
  inviter    User                    @relation("ReferralAttributionInviter", fields: [inviterId], references: [id], onDelete: Restrict)
  invitedId  String                  @map("invited_id") @db.Uuid
  invited    User                    @relation("ReferralAttributionInvitee", fields: [invitedId], references: [id], onDelete: Restrict)
  source     ReferralAttributionSource
  metadata   Json?
  createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([inviterId, invitedId])
  @@index([inviterId, createdAt])
  @@index([invitedId])
  @@map("referral_attribution_logs")
}

model Admin {
  id                 String              @id @default(uuid()) @db.Uuid
  email              String              @unique @db.VarChar(255)
  passwordHash       String              @map("password_hash")
  displayName        String              @map("display_name") @db.VarChar(160)
  role               AdminRole
  isActive           Boolean             @default(true) @map("is_active")
  lastLoginAt        DateTime?           @map("last_login_at") @db.Timestamptz(3)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt          DateTime?           @map("deleted_at") @db.Timestamptz(3)
  auditLogs          AuditLog[]
  financialAuditLogs FinancialAuditLog[]

  @@index([role, isActive])
  @@map("admins")
}

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(120)
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("settings")
}

model Notification {
  id                String              @id @default(uuid()) @db.Uuid
  userId            String              @map("user_id") @db.Uuid
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel           NotificationChannel
  type              NotificationType
  status            NotificationStatus  @default(PENDING)
  title             String              @db.VarChar(180)
  body              String
  templateKey       String?             @map("template_key") @db.VarChar(80)
  deduplicationKey  String?             @map("deduplication_key") @db.VarChar(160)
  referenceType     String?             @map("reference_type") @db.VarChar(80)
  referenceId       String?             @map("reference_id") @db.VarChar(160)
  payload           Json?
  scheduledAt       DateTime?           @map("scheduled_at") @db.Timestamptz(3)
  sentAt            DateTime?           @map("sent_at") @db.Timestamptz(3)
  readAt            DateTime?           @map("read_at") @db.Timestamptz(3)
  logs              NotificationLog[]
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([userId, deduplicationKey])
  @@index([userId, status])
  @@index([channel, scheduledAt])
  @@index([type, status, createdAt])
  @@map("notifications")
}

model NotificationLog {
  id             String       @id @default(uuid()) @db.Uuid
  notificationId String       @map("notification_id") @db.Uuid
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id") @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel        NotificationChannel
  attempt        Int          @default(1)
  status         NotificationStatus
  errorMessage   String?      @map("error_message")
  providerRef    String?      @map("provider_ref") @db.VarChar(160)
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([notificationId, createdAt])
  @@index([userId, createdAt])
  @@map("notification_logs")
}

model PaymentInvoice {
  id                    String               @id @default(uuid()) @db.Uuid
  userId                String               @map("user_id") @db.Uuid
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  walletId              String               @map("wallet_id") @db.Uuid
  provider              String               @db.VarChar(64)
  network               PaymentNetwork
  asset                 CurrencyCode
  fiatCurrency          CurrencyCode         @default(TOMAN) @map("fiat_currency")
  requestedToman        BigInt               @map("requested_toman")
  assetAmount           Decimal?             @map("asset_amount") @db.Decimal(36, 18)
  payAddress            String?              @map("pay_address") @db.VarChar(255)
  memo                  String?              @db.VarChar(255)
  status                PaymentInvoiceStatus @default(PENDING)
  confirmations         Int                  @default(0)
  requiredConfirmations Int                  @default(20) @map("required_confirmations")
  providerInvoiceId     String?              @map("provider_invoice_id") @db.VarChar(160)
  providerPaymentId     String?              @map("provider_payment_id") @db.VarChar(160)
  txHash                String?              @map("tx_hash") @db.VarChar(160)
  idempotencyKey        String               @unique @map("idempotency_key") @db.VarChar(160)
  expiresAt             DateTime             @map("expires_at") @db.Timestamptz(3)
  paidAt                DateTime?            @map("paid_at") @db.Timestamptz(3)
  metadata              Json?
  transactions          WalletTransaction[]
  webhooks              PaymentWebhook[]
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId, status, createdAt])
  @@index([provider, providerInvoiceId])
  @@index([status, expiresAt])
  @@index([txHash])
  @@map("payment_invoices")
}

model PaymentWebhook {
  id            String               @id @default(uuid()) @db.Uuid
  provider      String               @db.VarChar(64)
  eventId       String               @map("event_id") @db.VarChar(180)
  invoiceId     String?              @map("invoice_id") @db.Uuid
  invoice       PaymentInvoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  status        PaymentWebhookStatus @default(RECEIVED)
  signature     String?              @db.VarChar(512)
  payloadHash   String               @map("payload_hash") @db.VarChar(128)
  payload       Json
  processedAt   DateTime?            @map("processed_at") @db.Timestamptz(3)
  failureReason String?              @map("failure_reason")
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([provider, eventId])
  @@index([invoiceId, createdAt])
  @@index([status, createdAt])
  @@map("payment_webhooks")
}

model ReferralReward {
  id                  String               @id @default(uuid()) @db.Uuid
  referrerId          String               @map("referrer_id") @db.Uuid
  referrer            User                 @relation("ReferralRewardReferrer", fields: [referrerId], references: [id], onDelete: Restrict)
  refereeId           String               @map("referee_id") @db.Uuid
  referee             User                 @relation("ReferralRewardReferee", fields: [refereeId], references: [id], onDelete: Restrict)
  sourceTransactionId String?              @map("source_transaction_id") @db.Uuid
  rewardTransactionId String?              @map("reward_transaction_id") @db.Uuid
  percentageBps       Int                  @map("percentage_bps")
  fixedBonusToman     BigInt               @default(0) @map("fixed_bonus_toman")
  baseAmountToman     BigInt               @map("base_amount_toman")
  rewardAmountToman   BigInt               @map("reward_amount_toman")
  level               Int                  @default(1)
  status              ReferralRewardStatus @default(PENDING)
  releaseAt           DateTime?            @map("release_at") @db.Timestamptz(3)
  idempotencyKey      String               @unique @map("idempotency_key") @db.VarChar(160)
  metadata            Json?
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([referrerId, status])
  @@index([refereeId, createdAt])
  @@index([status, releaseAt])
  @@map("referral_rewards")
}

model Coupon {
  id                  String       @id @default(uuid()) @db.Uuid
  code                String       @unique @db.VarChar(64)
  status              CouponStatus @default(ACTIVE)
  discountBps         Int?         @map("discount_bps")
  discountAmountToman BigInt?      @map("discount_amount_toman")
  maxRedemptions      Int?         @map("max_redemptions")
  redeemedCount       Int          @default(0) @map("redeemed_count")
  startsAt            DateTime?    @map("starts_at") @db.Timestamptz(3)
  expiresAt           DateTime?    @map("expires_at") @db.Timestamptz(3)
  metadata            Json?
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, expiresAt])
  @@map("coupons")
}

model PricingRule {
  id              String            @id @default(uuid()) @db.Uuid
  name            String            @db.VarChar(160)
  status          PricingRuleStatus @default(ACTIVE)
  currency        CurrencyCode      @default(TOMAN)
  pricePerGbToman BigInt            @map("price_per_gb_toman")
  region          String?           @db.VarChar(80)
  userSegment     String?           @map("user_segment") @db.VarChar(80)
  priority        Int               @default(100)
  startsAt        DateTime?         @map("starts_at") @db.Timestamptz(3)
  endsAt          DateTime?         @map("ends_at") @db.Timestamptz(3)
  metadata        Json?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, priority])
  @@index([region, userSegment])
  @@map("pricing_rules")
}

model PurchaseDraft {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  user             User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  productId        String              @map("product_id") @db.Uuid
  product          Product             @relation(fields: [productId], references: [id], onDelete: Restrict)
  status           PurchaseDraftStatus @default(DRAFT)
  trafficGb        Int                 @map("traffic_gb")
  baseAmountToman  BigInt              @map("base_amount_toman")
  discountToman    BigInt              @default(0) @map("discount_toman")
  finalAmountToman BigInt              @map("final_amount_toman")
  reservedToman    BigInt              @default(0) @map("reserved_toman")
  currency         CurrencyCode        @default(TOMAN)
  pricingRuleId    String?             @map("pricing_rule_id") @db.Uuid
  couponCode       String?             @map("coupon_code") @db.VarChar(64)
  idempotencyKey   String              @unique @map("idempotency_key") @db.VarChar(160)
  metadata         Json?
  expiresAt        DateTime            @map("expires_at") @db.Timestamptz(3)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId, status, createdAt])
  @@index([status, expiresAt])
  @@index([productId])
  @@map("purchase_drafts")
}

model FinancialAuditLog {
  id            String               @id @default(uuid()) @db.Uuid
  action        FinancialAuditAction
  actorType     AuditActorType       @map("actor_type")
  actorUserId   String?              @map("actor_user_id") @db.Uuid
  actorAdminId  String?              @map("actor_admin_id") @db.Uuid
  actorAdmin    Admin?               @relation(fields: [actorAdminId], references: [id], onDelete: SetNull)
  userId        String?              @map("user_id") @db.Uuid
  walletId      String?              @map("wallet_id") @db.Uuid
  transactionId String?              @map("transaction_id") @db.Uuid
  invoiceId     String?              @map("invoice_id") @db.Uuid
  referenceId   String?              @map("reference_id") @db.VarChar(160)
  ipAddress     String?              @map("ip_address") @db.Inet
  userAgent     String?              @map("user_agent")
  metadata      Json?
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([transactionId])
  @@map("financial_audit_logs")
}

model SupportTicket {
  id           String                 @id @default(uuid()) @db.Uuid
  userId       String                 @map("user_id") @db.Uuid
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String                 @db.VarChar(180)
  category     TicketCategory         @default(GENERAL)
  status       SupportTicketStatus    @default(OPEN)
  priority     Int                    @default(0)
  slaDueAt     DateTime?              @map("sla_due_at") @db.Timestamptz(3)
  messages     SupportTicketMessage[]
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  closedAt     DateTime?              @map("closed_at") @db.Timestamptz(3)
  deletedAt    DateTime?              @map("deleted_at") @db.Timestamptz(3)

  @@index([userId, status])
  @@index([status, priority, createdAt])
  @@index([category, status])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id           String        @id @default(uuid()) @db.Uuid
  ticketId     String        @map("ticket_id") @db.Uuid
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId     String        @map("author_id") @db.Uuid
  isAdmin      Boolean       @default(false) @map("is_admin")
  body         String
  attachmentUrl String?      @map("attachment_url") @db.VarChar(512)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([ticketId, createdAt])
  @@map("support_ticket_messages")
}

model UserActivityLog {
